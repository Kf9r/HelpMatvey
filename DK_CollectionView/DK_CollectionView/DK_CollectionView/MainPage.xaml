<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://xamarin.com/schemas/2014/forms"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="DK_CollectionView.MainPage"
             BackgroundColor="#121212">

    <StackLayout Padding="15">

        <Entry Placeholder="Введите название события" 
               Text="{Binding Title}"
               BackgroundColor="#1E1E1E"
               PlaceholderColor="#757575"
               TextColor="#FFFFFF"
               HeightRequest="50" />

        <DatePicker Date="{Binding Date}"
                    BackgroundColor="#1E1E1E"
                    TextColor="#FFFFFF"
                    HeightRequest="50" />

        <Button Text="Добавить событие" 
                Command="{Binding AddEventCommand}"
                BackgroundColor="#BB86FC"
                TextColor="#000000"
                CornerRadius="8"
                HeightRequest="50"
                FontAttributes="Bold" />

        <Label Text="Ваши события"
               FontSize="20"
               FontAttributes="Bold"
               TextColor="#FFFFFF"
               Margin="0,10,0,5" />

        <CollectionView ItemsSource="{Binding Events}">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame BackgroundColor="#1E1E1E"
                           CornerRadius="12"
                           Padding="15"
                           Margin="0,5">
                        <StackLayout Spacing="5">
                            <Label Text="{Binding Title}" 
                                   FontSize="18" 
                                   FontAttributes="Bold"
                                   TextColor="#FFFFFF" />
                            <Label Text="{Binding Date, StringFormat='{0:dd MMMM yyyy, HH:mm}'}" 
                                   FontSize="14" 
                                   TextColor="#BB86FC" />
                        </StackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </StackLayout>

</ContentPage>