<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://xamarin.com/schemas/2014/forms"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="DK_FlexLayout.MainPage">

    <ScrollView>
        <StackLayout Spacing="20" >
            <Image Source="~Resources/Event_1.png" />

            <Label Text="Моя галерея"
                   FontSize="Large"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   Margin="0,0,0,20"/>

            <FlexLayout Direction="Row"
                       Wrap="Wrap"
                       JustifyContent="SpaceAround"
                       AlignItems="Center"
                       BindableLayout.ItemsSource="{Binding Images}">

                <BindableLayout.ItemTemplate>
                    <DataTemplate>
                        <Frame CornerRadius="10"
                               Padding="5"
                               Margin="5"
                               WidthRequest="150"
                               HeightRequest="150"
                               BackgroundColor="White"
                               HasShadow="True">

                            <Grid>
                                <Image Source="{Binding ImagePath}"
                                       Aspect="AspectFill"
                                       WidthRequest="140"
                                       HeightRequest="140"/>

                                <Grid.GestureRecognizers>
                                    <TapGestureRecognizer 
                                        Command="{Binding BindingContext.TapImageCommand}"
                                        CommandParameter="{Binding ImageName}"/>
                                </Grid.GestureRecognizers>
                            </Grid>
                        </Frame>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </FlexLayout>
        </StackLayout>
    </ScrollView>

</ContentPage>
